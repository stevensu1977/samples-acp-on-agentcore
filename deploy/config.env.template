# Copy to config.env and edit. Sourced by all deploy scripts.
# config.env is gitignored (it may hold account-specific values).

# AWS region for ECR + AgentCore. Defaults to us-east-1 if unset.
AWS_REGION=us-east-1

# Which agent to deploy: kiro | codex | claude
AGENT=claude

# AWS account id. Leave blank to auto-detect via STS.
AWS_ACCOUNT_ID=

# Shared AgentCore execution role name (created by 00_setup_iam.sh).
EXEC_ROLE_NAME=AcpOnAgentCoreExecutionRole

# --- Agent-specific knobs (optional) ---

# Bedrock model the Claude adapter uses (CLAUDE_CODE_USE_BEDROCK=1 in the image).
ANTHROPIC_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Pin the Kiro CLI download (ARM64) for reproducible builds.
KIRO_DOWNLOAD_URL=https://desktop-release.q.us-east-1.amazonaws.com/latest/kirocli-aarch64-linux.zip

# --- aws-data-analytics skills (Claude only) ---
# Inject the aws-data-analytics plugin's skills into Claude sessions.
ENABLE_AWS_DATA_SKILLS=true
# 'all' or a comma-separated whitelist of skill names, e.g.
#   querying-data-lake,exploring-data-catalog,finding-data-lake-assets
SKILL_SCOPE=all
# Optional aws-mcp MCP server (skills work via AWS CLI without it). Needs uv in image.
ENABLE_AWS_MCP=false

# --- Per-user scoped credentials (B layer, DESIGN §2.2) ---
# When true, the bridge assumes the execution role with a per-user session
# policy (scoped by the Runtime-User-Id header) before driving skills.
PER_USER_CREDS=false
# Bucket the per-user session policy scopes S3 access to (users/<id>/*).
DATA_BUCKET=

# --- Session persistence (DESIGN §3) ---
# Attach AgentCore Managed Session Storage at this mount (per-session, survives
# stop/resume; 14-day idle reset; wiped on runtime version update).
ENABLE_SESSION_STORAGE=true
SESSION_STORAGE_MOUNT=/mnt/workspace
# Optional: customer-owned S3 bucket for long-term archive/restore (DESIGN §3.6).
# Leave blank to disable. Managed session storage alone is NOT long-term durable.
ARCHIVE_BUCKET=
