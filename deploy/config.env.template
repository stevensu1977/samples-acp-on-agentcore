# Copy to config.env and edit. Sourced by all deploy scripts.
# config.env is gitignored (it may hold account-specific values).

# AWS region for ECR + AgentCore. Defaults to us-east-1 if unset.
AWS_REGION=us-east-1

# Which agent to deploy: kiro | codex | claude
AGENT=claude

# AWS account id. Leave blank to auto-detect via STS.
AWS_ACCOUNT_ID=

# Shared AgentCore execution role name (created by 00_setup_iam.sh).
EXEC_ROLE_NAME=AcpOnAgentCoreExecutionRole

# --- Agent-specific knobs (optional) ---

# Bedrock model the Claude adapter uses (CLAUDE_CODE_USE_BEDROCK=1 in the image).
ANTHROPIC_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Pin the Kiro CLI download (ARM64) for reproducible builds.
KIRO_DOWNLOAD_URL=https://desktop-release.q.us-east-1.amazonaws.com/latest/kirocli-aarch64-linux.zip
