# Claude Code agent image (self-contained, linux/arm64 for AgentCore).
#
# Claude Code is NOT ACP-native, so we install the official adapter
# (@agentclientprotocol/claude-agent-acp) — already a dependency of the bridge —
# which exposes the Claude Agent SDK as an ACP agent over stdio. The bridge then
# drives it like any other agent.

# --- build the bridge ---
FROM --platform=linux/arm64 node:22-bookworm-slim AS build
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install
COPY tsconfig.json ./
COPY src ./src
RUN npm run build

# --- runtime ---
FROM --platform=linux/arm64 node:22-bookworm-slim
ENV NODE_ENV=production
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install --omit=dev && npm cache clean --force
COPY --from=build /app/dist ./dist

# The adapter bin `claude-agent-acp` lives in node_modules/.bin.
ENV PATH="/app/node_modules/.bin:${PATH}"
ENV AGENT_ID=claude
ENV CLAUDE_ACP_BIN=claude-agent-acp
# Route the Claude Agent SDK through Amazon Bedrock so model access is
# authorized by the AgentCore execution role's IAM permissions (no API key).
ENV CLAUDE_CODE_USE_BEDROCK=1

# AgentCore HTTP contract: listen on 0.0.0.0:8080.
ENV PORT=8080
EXPOSE 8080
CMD ["node", "dist/server.js"]
