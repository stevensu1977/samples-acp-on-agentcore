# Codex CLI agent image (self-contained, linux/arm64 for AgentCore).
# Codex CLI speaks ACP natively (`codex acp`).

# --- build the bridge ---
FROM --platform=linux/arm64 node:22-bookworm-slim AS build
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install
COPY tsconfig.json ./
COPY src ./src
RUN npm run build

# --- runtime ---
FROM --platform=linux/arm64 node:22-bookworm-slim
ENV NODE_ENV=production
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install --omit=dev && npm cache clean --force
COPY --from=build /app/dist ./dist

# Install Codex CLI globally. Pin a version in CI for reproducibility.
RUN npm install -g @openai/codex && npm cache clean --force

ENV AGENT_ID=codex
ENV CODEX_BIN=codex
ENV CODEX_ACP_ARGS=acp

ENV PORT=8080
EXPOSE 8080
CMD ["node", "dist/server.js"]
