{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "InvokeAcpRuntimes",
      "Effect": "Allow",
      "Action": "bedrock-agentcore:InvokeAgentRuntime",
      "Resource": [
        "arn:aws:bedrock-agentcore:${AWS_REGION}:${AWS_ACCOUNT_ID}:runtime/acp-*",
        "arn:aws:bedrock-agentcore:${AWS_REGION}:${AWS_ACCOUNT_ID}:runtime/acp-*/*"
      ]
    }
  ]
}
